{
  // ============================================================
  // WINDOW & UI - ALLÉGÉ
  // ============================================================
  "window.autoDetectColorScheme": false,
  "window.zoomLevel": 1.7,
  "window.menuBarVisibility": "compact",
  "window.commandCenter": false,
  "window.titleBarStyle": "custom",
  // ============================================================
  // ZEN MODE
  // ============================================================
  "zenMode.fullScreen": true,
  "zenMode.showTabs": "none",
  "zenMode.centerLayout": true,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "symbols",
  "workbench.tips.enabled": false,
  "workbench.commandPalette.preserveInput": false,
  "workbench.editor.showTabs": "none",
  "workbench.editor.enablePreview": false,
  // ============================================================
  // SECURITE
  // ============================================================
  "security.workspace.trust.untrustedFiles": "open",
  // ============================================================
  // EXPLORER - MINIMAL
  // ============================================================
  "explorer.openEditors.visible": 1,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.autoReveal": true,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  // ============================================================
  // GIT - DÉSACTIVÉ
  // ============================================================
  "git.enabled": false,
  "git.autofetch": false,
  "git.decorations.enabled": false,
  // ============================================================
  // EDITOR - OPTIMISÉ
  // ============================================================
  "editor.fontFamily": "'Fira Code', 'JetBrains Mono', monospace",
  "editor.fontSize": 20,
  "editor.fontWeight": "400",
  "editor.fontLigatures": true,
  "editor.lineHeight": 50,
  "editor.padding.top": 0,
  "editor.tabSize": 3,
  "editor.detectIndentation": false,
  "editor.wordWrap": "on",
  "editor.lineNumbers": "off",
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "editor.renderLineHighlight": "none",
  "editor.guides.indentation": false,
  "editor.glyphMargin": false,
  "editor.showFoldingControls": "always",
  "editor.lightbulb.enabled": "off",
  "editor.codeLens": false,
  "editor.stickyScroll.enabled": false,
  "editor.hover.enabled": "off",
  "editor.occurrencesHighlight": "off",
  "editor.selectionHighlight": false,
  "editor.matchBrackets": "never",
  "editor.linkedEditing": false,
  // ============================================================
  // AUTOCOMPLETION - LÉGÈRE (essentiel pour PHP/React)
  // ============================================================
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "on",
    "other": "on"
  },
  "search.quickAccess.preserveInput": false,
  "search.quickOpen.includeHistory": false,
  "editor.suggestOnTriggerCharacters": true,
  "editor.parameterHints.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.tabCompletion": "off",
  "editor.acceptSuggestionOnEnter": "on",
  // ============================================================
  // FORMATAGE - ACTIVÉ UNIQUEMENT À LA SAUVEGARDE
  // ============================================================
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  // ============================================================
  // LANGUAGES SPÉCIFIQUES
  // ============================================================
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "editor.formatOnSave": true,
    "editor.quickSuggestions": {
      "other": true
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/vendor/**": true,
    "**/storage/**": true,
    "**/bower_components/**": true,
    "**/cache/**": true
  },
  // ============================================================
  // RECHERCHE - EXCLURE LES DOSSIERS LOURDS
  // ============================================================
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/vendor": true,
    "**/storage": true,
    ".git": true,
    "**/dist": true,
    "**/build": true,
    "_ide_helper.php": true,
    "_ide_helper_models.php": true,
    ".php_cs.cache": true,
    ".phpstorm.meta.php": true,
    ".phpunit.result.cache": true
  },
  // ============================================================
  // TERMINAL - SIMPLE
  // ============================================================
  "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.enablePersistentSessions": false,
  // ============================================================
  // TÉLÉMÉTRIE - DÉSACTIVÉ
  // ============================================================
  "update.mode": "none",
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  // ============================================================
  // EXPLORER PATTERNS
  // ============================================================
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "composer.json": "composer.lock",
    "psalm.xml": "psalm-baseline.xml",
    ".php-cs-fixer.php": ".php-cs-fixer.cache",
    "phpunit.xml": ".phpunit.result.cache",
    "*.php": "${basename}Test.php"
  },
  "emmet.includeLanguages": {
    "blade.php": "html",
    "twig": "html"
  },
  "files.associations": {
    ".php_cs.dist": "php",
    ".php_cs": "php",
    ".pre": "php",
    "artisan": "php"
  },
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "files.autoSave": "onFocusChange",
  "workbench.statusBar.visible": false,
  "workbench.colorTheme": "Dracula Theme Soft"
}
